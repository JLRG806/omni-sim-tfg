@startuml arquitectura_logica
skinparam {
    ArrowColor #A80036
    componentStyle uml2
    linetype polyline
    Nodesep 30
    Ranksep 35
}

skinparam package {
    BackgroundColor #FEFECE
    BorderColor #A80036
    FontStyle bold
}

skinparam component {
    BackgroundColor #B3D9FF
    BorderColor #2A5C9C
}

skinparam node {
    BackgroundColor #F5F5F5
    BorderColor #888888
}

' === Cliente ===
node "Cliente\n(Navegador web)" as Client {
    component "Vue SPA\n(HTML + CSS + JS)" as VueApp
}

' === Servidor Laravel ===
node "Servidor Laravel" as Server {
    package "Capa API" as L1 {
        component "Rutas + Middleware\n(Sanctum)" as API
    }
    package "Capa de Negocio" as L2 {
        component "Controladores + Servicios" as Business
    }
    package "Capa de Datos" as L3 {
        component "Modelos Eloquent" as Data
    }
    package "Capa de Persistencia" as L4 {
        component "PostgreSQL 16" as DB
    }

    API --> Business
    Business --> Data
    Data --> DB
}

' === Servicio externo ===
node "Orquestador IA\n(servicio externo)" as IA {
    component "n8n\n(workflows)" as N8N
    component "Ollama\n(modelo LLM)" as Ollama
    N8N --> Ollama
}

' === Comunicaciones ===
VueApp <--> API : JSON\n(API REST)
Business <--> N8N : REST + Webhooks\n(asíncrono)

@enduml