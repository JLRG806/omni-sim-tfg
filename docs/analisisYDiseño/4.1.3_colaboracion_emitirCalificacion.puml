@startuml colaboracion_emitirCalificacion
skinparam {
    ArrowColor #A80036
    componentStyle uml2
    linetype polyline
    Nodesep 40
    Ranksep 50
}

skinparam component {
    BackgroundColor<<view>> #B3D9FF
    BorderColor<<view>> #2A5C9C

    BackgroundColor<<ctrl>> #C8E6A0
    BorderColor<<ctrl>> #5C8C2A

    BackgroundColor<<model>> #FFD9A0
    BorderColor<<model>> #B07020

    BackgroundColor<<actor>> #F5F5F5
    BorderColor<<actor>> #888888
}

component "Profesor" as Prof <<actor>>
component "Orquestador IA" as IA <<actor>>

component "EmitirCalificacionView" as ECV <<view>>
component "emitirCalificacionController" as ECC <<ctrl>>
component "Resultados" as MRes <<model>>

' Acción previa generada en CU-29 (asíncrona)
IA ..> MRes : 0: generarBorrador()

' Flujo del CU-24
Prof --> ECV : 1: abrirEvaluacion(sesionId)
ECV --> ECC : 2: cargarBorrador(sesionId)
ECC --> MRes : 3: obtenerBorradorIA(sesionId)
Prof --> ECV : 4: ajustar(calificacion, feedback)
ECV --> ECC : 5: publicar(calificacion, feedback)
ECC --> MRes : 6: guardarEvaluacion(calificacion, feedback)

@enduml